---
const navLinks = [
  { href: '#open-source', label: 'Open Source' },
  { href: '#architecture', label: 'Architecture' },
  { href: '#values', label: 'Values' },
  { href: '#getting-started', label: 'Get Started' },
  { href: '#community', label: 'Community' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-slate-900/80 backdrop-blur-md border-b border-slate-800">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-white font-bold text-lg">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" class="w-8 h-8">
        <rect width="32" height="32" rx="4" fill="#0f172a"/>
        <rect x="6" y="20" width="20" height="4" rx="1" fill="#3b82f6"/>
        <rect x="6" y="14" width="20" height="4" rx="1" fill="#60a5fa"/>
        <rect x="6" y="8" width="20" height="4" rx="1" fill="#93c5fd"/>
      </svg>
      Sovereign Stack
    </a>

    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="text-sm text-slate-300 hover:text-white transition-colors">
          {label}
        </a>
      ))}
      <a
        href="https://github.com/faroshq/neocloud"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-slate-800 hover:bg-slate-700 rounded-lg border border-slate-700 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-slate-300 hover:text-white" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 bg-slate-900/95 backdrop-blur-md">
    <div class="px-6 py-4 flex flex-col gap-3">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="text-sm text-slate-300 hover:text-white transition-colors">
          {label}
        </a>
      ))}
      <a
        href="https://github.com/faroshq/neocloud"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-slate-300 hover:text-white"
      >
        GitHub
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
