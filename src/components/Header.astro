---
const navLinks = [
  { href: '#architecture', label: 'Architecture' },
  { href: '#open-source', label: 'Open Source' },
  { href: '#values', label: 'Why' },
  { href: '#getting-started', label: 'Get Started' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="absolute inset-0 bg-gray-950/0 backdrop-blur-none border-b border-white/0 transition-all duration-500" id="header-bg"></div>
  <nav class="relative max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group">
      <!-- Animated logo -->
      <div class="relative w-9 h-9">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 36" fill="none" class="w-9 h-9">
          <rect x="4" y="22" width="28" height="5" rx="1.5" fill="#3b82f6" class="origin-center transition-transform duration-300 group-hover:translate-y-[1px]"/>
          <rect x="4" y="15" width="28" height="5" rx="1.5" fill="#60a5fa" class="origin-center transition-transform duration-300 group-hover:translate-y-0"/>
          <rect x="4" y="8" width="28" height="5" rx="1.5" fill="#93c5fd" class="origin-center transition-transform duration-300 group-hover:-translate-y-[1px]"/>
        </svg>
      </div>
      <span class="text-white font-bold text-lg tracking-tight">Sovereign Stack</span>
    </a>

    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="relative px-4 py-2 text-sm text-slate-400 hover:text-white transition-colors rounded-lg hover:bg-white/5">
          {label}
        </a>
      ))}
      <div class="w-px h-5 bg-slate-800 mx-2"></div>
      <a
        href="https://github.com/faroshq/neocloud"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 hover:border-white/20 transition-all"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-slate-400 hover:text-white p-2 -mr-2" aria-label="Toggle menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5">
    <div class="glass px-6 py-4 flex flex-col gap-1">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="px-4 py-2.5 text-sm text-slate-400 hover:text-white hover:bg-white/5 rounded-lg transition-colors">
          {label}
        </a>
      ))}
      <a
        href="https://github.com/faroshq/neocloud"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2.5 text-sm text-slate-400 hover:text-white"
      >
        GitHub
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.add('hidden')));

  // Header scroll effect
  const header = document.getElementById('site-header');
  const headerBg = document.getElementById('header-bg');
  let ticking = false;

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const scrolled = window.scrollY > 60;
        if (headerBg) {
          headerBg.style.backgroundColor = scrolled ? 'rgba(3, 7, 18, 0.8)' : 'rgba(3, 7, 18, 0)';
          headerBg.style.backdropFilter = scrolled ? 'blur(16px) saturate(180%)' : 'none';
          headerBg.style.borderBottomColor = scrolled ? 'rgba(255,255,255,0.06)' : 'rgba(255,255,255,0)';
        }
        if (header) {
          const nav = header.querySelector('nav');
          if (nav) nav.style.paddingBlock = scrolled ? '12px' : '20px';
        }
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
