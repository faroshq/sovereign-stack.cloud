---
const values = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"/></svg>`,
    title: 'Zero License Fees',
    description: 'No subscriptions. No per-core pricing. No enterprise editions. Run your cloud without paying anyone for the privilege.',
    color: 'text-emerald-400',
    bg: 'bg-emerald-400/10',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`,
    title: 'Digital Sovereignty',
    description: 'Your hardware, your jurisdiction, your data. No US hyperscaler dependency. Full control over everything.',
    color: 'text-blue-400',
    bg: 'bg-blue-400/10',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0L21.75 16.5 12 21.75 2.25 16.5l4.179-2.25m0 0 5.571 3 5.571-3"/></svg>`,
    title: 'Composable',
    description: 'Pick the layers you need. Each piece is independently adoptable. No all-or-nothing decisions.',
    color: 'text-cyan-400',
    bg: 'bg-cyan-400/10',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>`,
    title: 'Battle-Tested',
    description: 'Built on CNCF graduated projects that run production workloads at scale. Not research prototypes.',
    color: 'text-indigo-400',
    bg: 'bg-indigo-400/10',
  },
];
---

<section id="values" class="relative py-28 md:py-36">
  <div class="divider-glow absolute top-0 left-0 right-0"></div>

  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal text-center mb-20">
      <p class="text-sm font-semibold text-indigo-400 tracking-widest uppercase mb-4">Why</p>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-5 tracking-tight">
        Why Sovereign Stack?
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {values.map(({ icon, title, description, color, bg }, i) => (
        <div
          class="reveal group relative rounded-2xl border border-white/[0.06] hover:border-white/[0.12] glass-subtle p-7 transition-all duration-500 hover:shadow-2xl"
          style={`transition-delay: ${i * 0.08}s`}
        >
          <!-- Hover glow -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-white/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

          <div class="relative">
            <div class={`w-11 h-11 rounded-xl ${bg} flex items-center justify-center mb-5 ${color}`} set:html={icon} />
            <h3 class="text-lg font-bold text-white mb-2">{title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
