---
const badges = [
  { label: 'CNCF Ecosystem', color: 'bg-blue-500/20 text-blue-300 border-blue-500/30' },
  { label: 'Apache 2.0', color: 'bg-green-500/20 text-green-300 border-green-500/30' },
  { label: 'EU Sovereign', color: 'bg-yellow-500/20 text-yellow-300 border-yellow-500/30' },
];
---

<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-blue-950/30 via-slate-900/0 to-slate-900/0 pointer-events-none"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-blue-500/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <!-- Badges -->
    <div class="flex flex-wrap justify-center gap-3 mb-8">
      {badges.map(({ label, color }) => (
        <span class={`inline-flex items-center px-3 py-1 text-xs font-medium rounded-full border ${color}`}>
          {label}
        </span>
      ))}
    </div>

    <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight tracking-tight mb-6">
      The Open Source<br />
      <span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">
        Sovereign Cloud Stack
      </span>
    </h1>

    <p class="text-lg md:text-xl text-slate-300 max-w-2xl mx-auto mb-10 leading-relaxed">
      A minimal, repeatable blueprint to build your own cloud &mdash; powered by the Kubernetes ecosystem.
      Take it, deploy it, and run your own cloud. Free of charge, free of licensing fees.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#getting-started"
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-lg transition-colors shadow-lg shadow-blue-600/25"
      >
        Get Started
      </a>
      <a
        href="https://github.com/faroshq/neocloud"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-semibold text-slate-200 bg-slate-800 hover:bg-slate-700 rounded-lg border border-slate-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>
  </div>
</section>
