---
const layers = [
  {
    id: 'infrastructure',
    number: '01',
    title: 'Infrastructure',
    subtitle: 'Bare metal to compute-ready Kubernetes',
    description: 'Automated provisioning, networking, storage, GPU, and VM support on commodity hardware.',
    color: 'blue',
    gradient: 'from-blue-600 to-blue-500',
    components: [
      { name: 'Metal3', badge: 'CNCF Sandbox', url: 'https://metal3.io' },
      { name: 'Flatcar Linux', badge: 'CNCF Sandbox', url: 'https://www.flatcar.org' },
      { name: 'Cluster API', badge: 'CNCF Incubating', url: 'https://cluster-api.sigs.k8s.io' },
      { name: 'Cilium', badge: 'CNCF Graduated', url: 'https://cilium.io' },
      { name: 'Rook-Ceph', badge: 'CNCF Graduated', url: 'https://rook.io' },
      { name: 'KubeVirt', badge: 'CNCF Incubating', url: 'https://kubevirt.io' },
      { name: 'NVIDIA GPU Operator', badge: 'Open Source', url: 'https://github.com/NVIDIA/gpu-operator' },
      { name: 'gVisor', badge: 'Open Source', url: 'https://gvisor.dev' },
    ],
  },
  {
    id: 'platform',
    number: '02',
    title: 'Platform',
    subtitle: 'Multi-tenant cloud APIs via kcp',
    description: 'Tenants get isolated workspaces with high-level APIs. They never see pods, nodes, or clusters.',
    color: 'cyan',
    gradient: 'from-cyan-600 to-cyan-500',
    components: [
      { name: 'kcp', badge: 'CNCF Sandbox', url: 'https://kcp.io' },
      { name: 'Cloud Operator', badge: 'Open Source', url: 'https://github.com/faroshq/neocloud' },
      { name: 'Zitadel IAM', badge: 'Open Source', url: 'https://zitadel.com' },
      { name: 'Compute API' },
      { name: 'VM API' },
      { name: 'Notebook API' },
      { name: 'GPU Jobs' },
      { name: 'Storage API' },
      { name: 'Network API' },
    ],
  },
  {
    id: 'production',
    number: '03',
    title: 'Production',
    subtitle: 'Billing, monitoring & day-2 operations',
    description: 'Everything needed to run as a production service — metering, observability, backup, TLS.',
    color: 'indigo',
    gradient: 'from-indigo-600 to-indigo-500',
    components: [
      { name: 'OpenMeter', badge: 'Open Source', url: 'https://openmeter.io' },
      { name: 'Prometheus', badge: 'CNCF Graduated', url: 'https://prometheus.io' },
      { name: 'Grafana', badge: 'Open Source', url: 'https://grafana.com/oss/grafana' },
      { name: 'VictoriaMetrics', badge: 'Open Source', url: 'https://victoriametrics.com' },
      { name: 'Velero', badge: 'CNCF Incubating', url: 'https://velero.io' },
      { name: 'cert-manager', badge: 'CNCF Incubating', url: 'https://cert-manager.io' },
    ],
  },
];

const badgeStyles: Record<string, string> = {
  'CNCF Graduated': 'text-emerald-400 bg-emerald-400/10',
  'CNCF Incubating': 'text-blue-400 bg-blue-400/10',
  'CNCF Sandbox': 'text-amber-400 bg-amber-400/10',
  'Open Source': 'text-slate-400 bg-slate-500/10',
};

const colorMap: Record<string, { ring: string; bg: string; text: string; glow: string; border: string }> = {
  blue: {
    ring: 'ring-blue-500/30',
    bg: 'bg-blue-500/10',
    text: 'text-blue-400',
    glow: 'shadow-blue-500/20',
    border: 'border-blue-500/20 hover:border-blue-500/40',
  },
  cyan: {
    ring: 'ring-cyan-500/30',
    bg: 'bg-cyan-500/10',
    text: 'text-cyan-400',
    glow: 'shadow-cyan-500/20',
    border: 'border-cyan-500/20 hover:border-cyan-500/40',
  },
  indigo: {
    ring: 'ring-indigo-500/30',
    bg: 'bg-indigo-500/10',
    text: 'text-indigo-400',
    glow: 'shadow-indigo-500/20',
    border: 'border-indigo-500/20 hover:border-indigo-500/40',
  },
};
---

<section id="architecture" class="relative py-28 md:py-36">
  <div class="divider-glow absolute top-0 left-0 right-0"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal text-center mb-20">
      <p class="text-sm font-semibold text-blue-400 tracking-widest uppercase mb-4">Architecture</p>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-5 tracking-tight">
        Three Layers. One Stack.
      </h2>
      <p class="text-lg text-slate-400 max-w-xl mx-auto font-light">
        Each layer is independently adoptable. Start small, scale up.
      </p>
    </div>

    <!-- Interactive 3D Stack -->
    <div class="max-w-4xl mx-auto">
      <!-- Visual stack with perspective -->
      <div class="relative" style="perspective: 1200px;">
        <div class="space-y-4">
          {layers.map((layer, i) => {
            const colors = colorMap[layer.color];
            return (
              <div
                class="reveal"
                style={`transition-delay: ${i * 0.12}s`}
              >
                <button
                  data-layer={layer.id}
                  class={`layer-btn group w-full text-left rounded-2xl border ${colors.border} glass transition-all duration-500 cursor-pointer hover:shadow-xl ${colors.glow}`}
                  aria-expanded="false"
                >
                  <div class="p-6 md:p-7">
                    <div class="flex items-center gap-5">
                      <!-- Layer number -->
                      <div class={`relative flex-shrink-0 w-14 h-14 rounded-xl bg-gradient-to-br ${layer.gradient} flex items-center justify-center shadow-lg ${colors.glow}`}>
                        <span class="text-white font-black text-xl">{layer.number}</span>
                      </div>

                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 mb-1">
                          <h3 class="text-lg md:text-xl font-bold text-white">{layer.title}</h3>
                          <span class={`text-[11px] font-medium px-2.5 py-0.5 rounded-full ${colors.bg} ${colors.text}`}>
                            {layer.components.length} components
                          </span>
                        </div>
                        <p class="text-sm text-slate-400">{layer.subtitle}</p>
                      </div>

                      <div class={`flex-shrink-0 w-8 h-8 rounded-lg ${colors.bg} flex items-center justify-center transition-transform duration-300 layer-chevron`}>
                        <svg class={`w-4 h-4 ${colors.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
                        </svg>
                      </div>
                    </div>
                  </div>

                  <!-- Expandable component grid -->
                  <div data-panel={layer.id} class="layer-panel hidden">
                    <div class="px-6 md:px-7 pb-6 md:pb-7 pt-1">
                      <p class="text-sm text-slate-400 mb-5">{layer.description}</p>
                      <div class="grid grid-cols-2 md:grid-cols-4 gap-2.5 stagger-children">
                        {layer.components.map(({ name, badge, url }) => {
                          const inner = (
                            <div class="p-3 rounded-xl bg-white/[0.03] border border-white/[0.06] hover:border-white/[0.12] hover:bg-white/[0.05] transition-all duration-200 h-full">
                              <p class="text-sm font-medium text-white mb-1">{name}</p>
                              {badge && (
                                <span class={`text-[10px] font-medium px-2 py-0.5 rounded-full ${badgeStyles[badge] || ''}`}>
                                  {badge}
                                </span>
                              )}
                            </div>
                          );
                          return url ? (
                            <a href={url} target="_blank" rel="noopener noreferrer" class="group/c">
                              {inner}
                            </a>
                          ) : (
                            <div>{inner}</div>
                          );
                        })}
                      </div>
                    </div>
                  </div>
                </button>
              </div>
            );
          })}
        </div>

        <!-- Connecting lines between layers -->
        <div class="absolute left-10 top-0 bottom-0 w-px pointer-events-none hidden md:block" style="background: linear-gradient(180deg, transparent, rgba(59,130,246,0.15) 20%, rgba(6,182,212,0.15) 50%, rgba(99,102,241,0.15) 80%, transparent);"></div>
      </div>

      <!-- Hardware base -->
      <div class="reveal mt-6 max-w-4xl mx-auto">
        <div class="flex items-center gap-4 px-6 py-4 rounded-2xl bg-white/[0.02] border border-dashed border-white/[0.06]">
          <div class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center">
            <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-slate-400">Your Hardware</p>
            <p class="text-xs text-slate-600">Bare metal servers, VMs, or cloud instances &mdash; any x86/ARM</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .layer-btn[aria-expanded="true"] .layer-chevron {
    transform: rotate(180deg);
  }

  .layer-panel {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .layer-panel.expanded {
    max-height: 500px;
    opacity: 1;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.layer-btn');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const layerId = btn.dataset.layer;
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      const panel = document.querySelector<HTMLElement>(`[data-panel="${layerId}"]`);

      // Close all other panels
      buttons.forEach((b) => {
        if (b !== btn) {
          b.setAttribute('aria-expanded', 'false');
          const otherPanel = b.querySelector<HTMLElement>('.layer-panel');
          if (otherPanel) {
            otherPanel.classList.remove('expanded');
            otherPanel.classList.add('hidden');
          }
        }
      });

      if (isExpanded) {
        btn.setAttribute('aria-expanded', 'false');
        if (panel) {
          panel.classList.remove('expanded');
          setTimeout(() => panel.classList.add('hidden'), 300);
        }
      } else {
        btn.setAttribute('aria-expanded', 'true');
        if (panel) {
          panel.classList.remove('hidden');
          // Trigger stagger animation
          const stagger = panel.querySelector('.stagger-children');
          if (stagger) stagger.classList.add('visible');
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              panel.classList.add('expanded');
            });
          });
        }
      }
    });
  });
</script>
